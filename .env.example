# =========================================================================
# QKD Security Portal Environment Variables Configuration Example Template
# Duplicate this file to '.env' and fill in your custom values.
# =========================================================================

# Database Configuration
# - For Local SQLite Development: sqlite:///./quantum.db
# - For Docker PostgreSQL Setup: postgresql://postgres:postgres123@db:5432/quantum_cryptography
DATABASE_URL=postgresql://postgres:postgres123@db:5432/quantum_cryptography

# PostgreSQL Container Credentials (used by db service in docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=quantum_cryptography

# JWT Token Secret Configurations
JWT_SECRET=QUANTUM_CRYPTOGRAPHY_SUPER_SECRET_KEY_JWT_TOKEN
JWT_ALGORITHM=HS256

# Next.js API Connection Settings (tells frontend where the backend lives)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional Payment Processor Configurations (Stripe / Razorpay)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Optional Search Engine Configurations (Meilisearch / Elasticsearch)
MEILISEARCH_HOST=
MEILISEARCH_KEY=
ELASTICSEARCH_URL=

# Optional Notification & Alert Settings (Twilio SMS / Firebase)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
FIREBASE_PUSH_SERVER_KEY=

# Optional Analytics Integration Settings
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_CLARITY_ID=

